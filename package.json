{
  "name": "@cryptoapis-io/mcp-signer",
  "version": "0.2.1",
  "description": "MCP server for local transaction signing across EVM, UTXO, Tron, and XRP blockchains — no API calls required",
  "license": "MIT",
  "author": "Crypto APIs, Inc.",
  "repository": {
    "type": "git",
    "url": "https://github.com/CryptoAPIs-io/cryptoapis-mcp-signer.git"
  },
  "keywords": [
    "mcp",
    "cryptoapis",
    "blockchain",
    "signer",
    "transaction-signing",
    "evm",
    "utxo",
    "tron",
    "xrp"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "cryptoapis-mcp-signer": "dist/cli.js"
  },
  "dependencies": {
    "@cryptoapis-io/mcp-shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.25.1",
    "bitcoinjs-lib": "^7.0.0",
    "ecpair": "^2.1.0",
    "elliptic": "^6.6.1",
    "ethers": "^6.13.0",
    "tiny-secp256k1": "^2.2.3",
    "xrpl": "^4.6.0",
    "zod": "^3.25.0"
  },
  "scripts": {
    "dev": "tsx watch src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "node -e \"console.log('lint: add eslint if you want')\"",
    "test": "node -e \"console.log('test: add later')\"",
    "test:sepolia-sign": "tsx scripts/test-sepolia-sign.ts",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "rimraf": "^6.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.5.4"
  }
}
